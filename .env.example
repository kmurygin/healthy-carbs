# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/healthy_carbs
DB_USERNAME=
DB_PASSWORD=

# Postgres db docker container configuration
POSTGRES_DB=healthy_carbs
POSTGRES_USER=${DB_USERNAME}
POSTGRES_PASSWORD=${DB_PASSWORD}

# JWT Configuration
# Generate a secure 256-bit secret key (64 hex characters)
# You can generate one using: openssl rand -hex 32
JWT_SECRET_KEY=

# Email Configuration
# Configure your SMTP settings for sending emails
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Spring Profile
# Available profiles: dev, prod
SPRING_PROFILES_ACTIVE=dev

# PayU Payment Integration
PAYU_BASE_URL=
PAYU_POS_ID=
PAYU_CLIENT_ID=
PAYU_CLIENT_SECRET=
PAYU_SECOND_KEY=
PAYU_NOTIFY_URL=
PAYU_CONTINUE_URL=
PAYU_CURRENCY=PLN

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:4200

DB_POOL_SIZE=5

STORAGE_BUCKET_NAME=
STORAGE_PUBLIC_URL_BASE=
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_CACHE_CONTROL=public, max-age=1209600

# Google Cloud Storage
#GCP_PROJECT_ID=
#GCS_BUCKET_NAME=
#GCS_PUBLIC_URL_BASE=
#GCP_STORAGE_ENABLED=false
#GCP_CORE_ENABLED=false
#GOOGLE_APPLICATION_CREDENTIALS=

# Local storage (dev profile)
LOCAL_UPLOAD_DIR=uploads
LOCAL_BASE_URL=/api/v1/files
